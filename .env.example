# ============================================================
# VietGo Japan — Environment Variables
# Copy to .env.local for development. Never commit real secrets.
# Only VITE_* variables are exposed to the browser.
# ============================================================

# App
VITE_APP_NAME=VietGo Japan
VITE_APP_URL=http://localhost:5173

# Supabase (public — safe for browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Cloudflare Turnstile (site key is public)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Optional public contact placeholders (do not invent real license data)
VITE_CONTACT_PHONE=
VITE_CONTACT_EMAIL=
VITE_CONTACT_LINE_ID=
VITE_CONTACT_ADDRESS=

# ------------------------------------------------------------
# SERVER-SIDE ONLY — set in Supabase Edge Function secrets
# or CI. NEVER put these in VITE_* or commit them.
# ------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=
# TURNSTILE_SECRET_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@yourdomain.example
# ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.example
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
